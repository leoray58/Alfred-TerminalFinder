      <dict>
        <key>applescript</key>
        <string>on alfred_script(q)
  tell application "Finder"
    set pathList to ""
    try
      set theSelection to selection
      if (count of theSelection) &gt; 0 then
        set theItem to item 1 of theSelection
        set itemClass to class of theItem
        if itemClass is folder or itemClass is disk then
          set pathList to POSIX path of (theItem as alias)
        end if
      end if
    end try

    if pathList is "" then
      set pathList to POSIX path of (folder of the front window as alias)
    end if
  end tell

  tell application "Ghostty"
    set cfg to new surface configuration
    set initial working directory of cfg to pathList
    new window with configuration cfg
    activate
  end tell
end alfred_script</string>
